:80 {
  root * /app/dist
  
  # Set MIME types using regex matchers
  @js path_regexp \.js$
  header @js Content-Type "application/javascript; charset=utf-8"
  
  @css path_regexp \.css$
  header @css Content-Type "text/css; charset=utf-8"
  
  @wasm path_regexp \.wasm$
  header @wasm Content-Type "application/wasm"
  
  # Serve static files with compression
  file_server
  encode gzip
  
  # SPA routing - rewrite non-existent paths to index.html
  rewrite {
    if {http.request.uri} not ^/static
    if {http.request.uri} not ^/assets
    if {http.request.uri} not ^/node_modules
    if {http.request.uri} not ^/favicon
    if {http.request.uri} not ^/manifest
    if {http.request.uri} not ^/logo
    to /index.html
  }
}
