:80 {
  root * /app/dist
  
  # Match existing files
  @exist {
    file
    try_files {path}
  }
  
  # Serve existing files with proper headers
  handle @exist {
    header Content-Type "text/plain"
    file_server
  }
  
  # Fallback for everything else (SPA)
  handle {
    rewrite * /index.html
    file_server
  }
  
  encode gzip
}
