:80 {
  root * /app/dist
  encode gzip
  
  # Match static files and serve with proper headers
  @staticFiles {
    path *.js *.css *.wasm *.png *.jpg *.jpeg *.gif *.svg *.ico *.webp *.json *.woff *.woff2 *.ttf *.eot
  }
  
  header @staticFiles Cache-Control "public, max-age=31536000, immutable"
  
  # Serve matched static files
  route @staticFiles {
    file_server
  }
  
  # SPA routing for everything else
  route {
    try_files {path} /index.html
    file_server
  }
}
