:80 {
  root * /app/dist
  encode gzip
  
  # Match non-static files (for SPA routing)
  @notStatic {
    file {
      try_files {path} /index.html
    }
  }
  
  # Serve SPA fallback only for non-existent paths
  handle @notStatic {
    rewrite * /index.html
    file_server
  }
  
  # Serve all other files normally (with correct MIME types)
  handle {
    file_server
  }
}
