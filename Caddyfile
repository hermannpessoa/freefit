:80 {
  root * /app/dist
  encode gzip
  file_server
  
  # Critical: Set JavaScript MIME type for all .js files
  header *.js Content-Type "application/javascript; charset=utf-8"
  header *.mjs Content-Type "application/javascript; charset=utf-8"
  
  # WebAssembly support
  header *.wasm Content-Type "application/wasm"
  
  # Ensure cache headers don't cause issues
  header *.js Cache-Control "public, max-age=3600"
  header *.css Cache-Control "public, max-age=3600"
  header *.wasm Cache-Control "public, max-age=3600"
  header /index.html Cache-Control "public, max-age=0, must-revalidate"
  
  # SPA routing: Always serve index.html for non-file requests
  try_files {path} /index.html
}
