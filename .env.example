# ⚠️ IMPORTANTE: NÃO commitar arquivo .env.local com credenciais reais!
# Este arquivo é apenas um template. Crie .env.local com suas credenciais.

# Supabase Configuration
# Obter em: https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=

# OpenRouter API Configuration
# Obter em: https://openrouter.ai → Account → API Keys
# Formato: sk-or-v1-...
VITE_OPENROUTER_API_KEY=sk-or-v1-sua-chave-aqui

# Replicate API Configuration (para geração de imagens)
# Obter em: https://replicate.com → Account → API Tokens
VITE_REPLICATE_API_KEY=

